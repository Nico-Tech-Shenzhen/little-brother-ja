# Canonical source files: preserve exact bytes, no newline conversion
source/original/*.txt -text
source/original/*.htm -text

# Generated section files: always LF
source/sections/*.txt text eol=lf

# Scripts and config: always LF
*.py   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.tsv  text eol=lf
*.mts  text eol=lf
*.ts   text eol=lf
*.css  text eol=lf
